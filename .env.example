# Variables privadas para Vercel.
# Nunca publiques la conexión real de Neon.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require

# Opcional. Si no se configura, Duke usa 2003.
DUKE_ACCESS_CODE=2003

# Opcional pero recomendado para que las llamadas funcionen incluso
# entre redes móviles, routers estrictos o Wi-Fi corporativo.
# Puedes colocar varias URL separadas por comas.
TURN_URL=turn:TU-SERVIDOR:3478,turns:TU-SERVIDOR:5349
TURN_USERNAME=TU_USUARIO
TURN_CREDENTIAL=TU_CONTRASENA
